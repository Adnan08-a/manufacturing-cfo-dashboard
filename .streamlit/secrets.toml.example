# Copy this file to .streamlit/secrets.toml and fill in your own key to enable
# live AI Q&A on the "AI Insights" page. This file (secrets.toml) should never
# be committed to GitHub -- only secrets.toml.example is tracked.
#
# On Streamlit Community Cloud, paste the same contents into:
#   App settings -> Secrets

ANTHROPIC_API_KEY = "sk-ant-your-key-here"
